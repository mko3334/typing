// 難易度自動判定ロジック
const hasSymbolOrNumber = (text) => {
  return /[！？!?。、,.\d０-９]/.test(text);
};

const determineDifficulty = (word) => {
  const len = word.length;
  if (hasSymbolOrNumber(word)) {
    return 'ベリーハード';
  } else if (len === 2) {
    return 'イージー';
  } else if (len >= 3 && len <= 5) {
    return 'ノーマル';
  } else {
    return 'ハード';
  }
};

