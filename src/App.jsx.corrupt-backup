                  className="w-full p-2.5 rounded-xl border-2 border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-sm font-bold text-gray-700"
                />
              </div>

              {/* チケット選択グリッド */}
              <div className="grid grid-cols-2 gap-2">
                <div>
                  <label className="text-[10px] font-black text-pink-600 block mb-0.5">🎨 はいけいチケット</label>
                  <input
                    type="number"
                    min="0"
                    value={giftSpecialTickets}
                    onChange={(e) => setGiftSpecialTickets(Math.max(0, parseInt(e.target.value) || 0))}
                    className="w-full p-2 rounded-lg border border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-xs font-bold text-gray-700"
                  />
                </div>
                <div>
                  <label className="text-[10px] font-black text-pink-600 block mb-0.5">🌟 激レア以上確定チケット</label>
                  <input
                    type="number"
                    min="0"
                    value={giftLegendTickets}
                    onChange={(e) => setGiftLegendTickets(Math.max(0, parseInt(e.target.value) || 0))}
                    className="w-full p-2 rounded-lg border border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-xs font-bold text-gray-700"
                  />
                </div>
                <div>
                  <label className="text-[10px] font-black text-pink-600 block mb-0.5">🎵 音楽チケット</label>
                  <input
                    type="number"
                    min="0"
                    value={giftBgmTickets}
                    onChange={(e) => setGiftBgmTickets(Math.max(0, parseInt(e.target.value) || 0))}
                    className="w-full p-2 rounded-lg border border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-xs font-bold text-gray-700"
                  />
                </div>
                <div>
                  <label className="text-[10px] font-black text-pink-600 block mb-0.5">🔊 効果音チケット</label>
                  <input
                    type="number"
                    min="0"
                    value={giftSeTickets}
                    onChange={(e) => setGiftSeTickets(Math.max(0, parseInt(e.target.value) || 0))}
                    className="w-full p-2 rounded-lg border border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-xs font-bold text-gray-700"
                  />
                </div>
              </div>

              {/* メッセージ */}
              <div>
                <label className="text-xs font-black text-pink-600 block mb-1">💬 メッセージ（ひとこと）</label>
                <textarea
                  value={giftMessage}
                  onChange={(e) => setGiftMessage(e.target.value)}
                  placeholder="ワードさいよう おめでとう！ など"
                  rows="3"
                  maxLength={150}
                  className="w-full p-2.5 rounded-xl border-2 border-pink-100 focus:border-pink-500 focus:outline-none bg-white text-xs font-bold text-gray-700 resize-none"
                />
              </div>
            </div>
              >
                {isSaving ? "送信中..." : "🎁 おくる！"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* プレイヤープレゼント受け取りモーダル */}
      {isGiftRewardModalOpen && activeGift && (
        <div className="fixed inset-0 bg-black/70 backdrop-blur-md z-[110] flex items-center justify-center p-4 animate-fade-in">
          <div className="glass-card bg-white/95 w-full max-w-md p-6 shadow-2xl rounded-3xl border-4 border-yellow-400 text-center animate-scale-in">
            <span className="text-6xl block mb-3 animate-bounce">🎉 🎁 🎉</span>
            <h3 className="text-xl sm:text-2xl font-black text-yellow-600 mb-1 animate-pulse">
              プレゼントが とどいたよ！
            </h3>
            <p className="text-xs text-gray-500 font-bold mb-4">
              かんりしゃ から プレゼントが おくられたよ！
            </p>

            {/* メッセージ */}
            {activeGift.message && (
              <div className="bg-yellow-50 border border-yellow-100 p-4 rounded-2xl mb-4 text-center">
                <span className="text-[10px] text-yellow-600 font-black block mb-1">💬 かんりしゃ からの メッセージ</span>
                <p className="text-sm font-black text-gray-800 break-words whitespace-pre-wrap">
                  「 {activeGift.message} 」
                </p>
              </div>
            )}
                )}
                {(activeGift.specialTickets || 0) > 0 && (
                  <div className="flex items-center gap-2 font-black text-gray-700 bg-white/80 p-2 rounded-xl border border-orange-100">
                    <span className="text-xl">🎟️</span>
                    <span>激レアチケット × {activeGift.specialTickets}</span>
                  </div>
                )}
                {(activeGift.legendTickets || 0) > 0 && (
                  <div className="flex items-center gap-2 font-black text-gray-700 bg-white/80 p-2 rounded-xl border border-orange-100">
                    <span className="text-xl">👑</span>
                    <span>伝説チケット × {activeGift.legendTickets}</span>
                  </div>
                )}
                {(activeGift.bgmTickets || 0) > 0 && (
                  <div className="flex items-center gap-2 font-black text-gray-700 bg-white/80 p-2 rounded-xl border border-orange-100">
                    <span className="text-xl">🎵</span>
                    <span>音楽チケット × {activeGift.bgmTickets}</span>
                  </div>
                )}
                {(activeGift.seTickets || 0) > 0 && (
                  <div className="flex items-center gap-2 font-black text-gray-700 bg-white/80 p-2 rounded-xl border border-orange-100">
                    <span className="text-xl">🔊</span>
                    <span>効果音チケット × {activeGift.seTickets}</span>
                  </div>
                )}
              </div>
            </div>

            <button
              onClick={handleAcceptGift}
              className="w-full py-3 bg-gradient-to-r from-yellow-500 to-amber-500 hover:from-yellow-600 hover:to-amber-600 text-white font-black text-base rounded-2xl shadow-lg active:scale-95 transition-all cursor-pointer flex items-center justify-center gap-2"
            >
              <span>😆</span> ありがとう！ <span>🙌</span>
            </button>
          </div>
        </div>
              </div>
            </div>

            <button
              onClick={handleAcceptGift}
              className="w-full py-3 bg-gradient-to-r from-yellow-500 to-amber-500 hover:from-yellow-600 hover:to-amber-600 text-white font-black text-base rounded-2xl shadow-lg active:scale-95 transition-all cursor-pointer flex items-center justify-center gap-2"
            >
              <span>😆</span> ありがとう！ <span>🙌</span>
            </button>
          </div>
        </div>
      )}

      {/* 採用確認モーダル */}
      {adoptingRequest && (
        <div className="fixed inset-0 bg-black/60 backdrop-blur-sm z-55 flex items-center justify-center p-4 animate-fade-in">
          <div className="glass-card bg-white/95 w-full max-w-md p-6 shadow-2xl rounded-3xl border-4 border-green-400 text-center animate-scale-in">
            <span className="text-5xl block mb-3 animate-bounce">🎉</span>
            <h3 className="text-lg sm:text-xl font-black text-gray-800 mb-2">リクエストを 採用する</h3>
            <p className="text-xs text-gray-500 font-bold mb-4">
              このキーワードをゲームの単語リストに追加します
            </p>
            
            {/* 単語詳細 */}
            <div className="bg-green-50 border border-green-100 p-4 rounded-2xl mb-5 text-left space-y-1.5">
              <div>
                <span className="text-[10px] text-green-600 font-black block">かな（なまえ）</span>
                <span className="text-base font-black text-gray-800">{adoptingRequest.kana}</span>
              </div>
              <div>
                <span className="text-[10px] text-green-600 font-black block">ローマ字</span>
                <span className="text-xs font-mono text-gray-600">
                  {Array.isArray(adoptingRequest.romaji) ? adoptingRequest.romaji.join(' / ') : adoptingRequest.romaji}
                </span>
              </div>
                    <div className="text-xs tracking-wider">こうかおんの</div>
                    <div className="text-base mt-1">ガチャチケット</div>
                  </div>
                ) : ticketReward.type === 'bgm' ? (
                  <div className="w-48 py-8 rounded-2xl bg-gradient-to-r from-emerald-500 to-teal-500 border-4 border-yellow-300 text-white font-black text-center shadow-lg transform rotate-3 hover:rotate-0 transition-transform duration-300 relative overflow-hidden">
                    <div className="text-5xl mb-2 animate-bounce">🎵💿🎵</div>
                    <div className="text-xs tracking-wider">おんがくの</div>
                    <div className="text-base mt-1">ガチャチケット</div>
                  </div>
                ) : (
                  <div className="w-48 py-8 rounded-2xl bg-gradient-to-r from-yellow-400 to-amber-500 border-4 border-yellow-300 text-white font-black text-center shadow-lg transform -rotate-3 hover:rotate-0 transition-transform duration-300 relative overflow-hidden">
                    <div className="text-5xl mb-2 animate-bounce">🎨🎟️🎨</div>
                    <div className="text-xs tracking-wider">はいけいの</div>
                    <div className="text-base mt-1">ガチャチケット</div>
                  </div>
                )}
              </div>
              
              <p className="text-base font-black text-gray-700 leading-snug">
                {ticketReward.type === 'legend' 
                  ? '🌟 激レア以上確定チケット 🌟' 
                  : ticketReward.type === 'se'
                  ? '🔊 こうかおんガチャチケット 🔊'
                  : ticketReward.type === 'bgm'
                  ? '🎵 おんがくガチャチケット 🎵'
                  : '🎨 はいけいガチャチケット 🎨'}
                <br />
                を {ticketReward.count || 1}まい ゲットしたよ！
              </p>
              
              <button
                onClick={() => {
                  const onConfirm = ticketReward.onConfirm;
                  setTicketReward(null);
                  if (onConfirm) onConfirm();
                }}
                className="premium-button bg-gradient-to-r from-yellow-400 to-orange-500 hover:from-yellow-500 hover:to-orange-600 text-white font-black text-lg px-8 py-3 w-full shadow-lg"
              >
                {ticketReward.titleObj ? 'やったー！' : 'つぎへすすむ'}
              </button>
            </div>
          </div>
        </div>
      )}

    {/* 初回同期ローディング */}
    {isSyncing && (
      <div className="fixed inset-0 bg-sky-500 z-[100] flex flex-col items-center justify-center p-4">
        <div className="text-white text-5xl mb-4 animate-bounce">☁️</div>
        <h2 className="text-white text-xl md:text-2xl font-black mb-2">データをよみこみ中...</h2>
        <div className="w-48 h-2 bg-sky-400 rounded-full overflow-hidden">
          <div className="w-1/2 h-full bg-white animate-pulse" />
        </div>
      </div>
    )}



    </div>
  );
}

